# Runtime
NODE_ENV=development
PORT=4000
API_PUBLIC_URL=http://localhost:4000
ADMIN_PUBLIC_URL=http://localhost:3000
LOG_LEVEL=info

# Database / queues
DATABASE_URL=postgresql://dropship:dropship@localhost:5432/dropship_os
REDIS_URL=redis://localhost:6379

# Shopify
SHOPIFY_SHOP_DOMAIN=your-new-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_redacted
SHOPIFY_API_VERSION=2026-04
SHOPIFY_WEBHOOK_SECRET=replace_with_shopify_app_secret
SHOPIFY_STORE_BASE_CURRENCY=USD
SHOPIFY_MARKETS_ENABLED=true

# Payments
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-redacted
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-redacted
FLUTTERWAVE_SECRET_HASH=replace_with_flutterwave_secret_hash
FLUTTERWAVE_TEST_MODE=true
# Optional for this Flutterwave-first launch.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
STRIPE_SECRET_KEY=

# AI
OPENAI_API_KEY=sk-redacted
OPENAI_MODEL=gpt-5.2
OPENAI_PROMPT_CACHE_RETENTION=24h

# Suppliers
# Reserved for future official Zendrop API access; current fulfillment uses the supported Shopify-connected Zendrop dashboard flow.
ZENDROP_API_KEY=
ZENDROP_CONNECTED_STORE_ENABLED=true
SPOCKET_API_KEY=replace_with_spocket_key
CJ_API_KEY=replace_with_cj_key
AUTODS_API_KEY=replace_with_autods_key
DSERS_API_KEY=replace_with_dsers_key
SUPPLIER_WEBHOOK_SECRET=replace_with_supplier_hmac_secret

# Marketing / analytics
KLAVIYO_PRIVATE_API_KEY=replace_with_klaviyo_key
META_ACCESS_TOKEN=replace_with_meta_token
META_AD_ACCOUNT_ID=act_replace_with_meta_ad_account
META_PIXEL_ID=replace_with_pixel_id
TIKTOK_ACCESS_TOKEN=replace_with_tiktok_token
TIKTOK_ADVERTISER_ID=replace_with_tiktok_advertiser_id
TIKTOK_PIXEL_ID=replace_with_tiktok_pixel
POSTHOG_KEY=replace_with_posthog_key
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=

# n8n
N8N_ENCRYPTION_KEY=replace_with_32_plus_char_random_key
N8N_BASIC_AUTH_USER=ops
N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password

# Feature flags
AUTO_FULFILLMENT_ENABLED=false
PAID_ADS_ENABLED=false
AI_AUTO_PUBLISH_ENABLED=false
STRIPE_ENABLED=false
SHOPIFY_LIVE_WRITE_ENABLED=false
SUPPLIER_AUTO_PAY_ENABLED=false
CUSTOMER_AI_AUTO_REPLY_ENABLED=false
