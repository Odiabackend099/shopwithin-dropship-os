{% assign current_variant = product.selected_or_first_available_variant %}
<section class="product-shell" data-product-id="{{ product.id }}">
  <div class="product-media">
    {% if product.featured_media %}
      {{ product.featured_media | image_url: width: 1100 | image_tag: loading: 'eager', widths: '375,550,750,1100', sizes: '(max-width: 760px) 100vw, 50vw', class: 'hero-media' }}
    {% endif %}
    {% if section.settings.show_ugc_video and product.metafields.custom.ugc_video_url != blank %}
      <div class="ugc-frame">
        <video src="{{ product.metafields.custom.ugc_video_url }}" controls playsinline preload="metadata"></video>
      </div>
    {% endif %}
  </div>

  <div class="product-info">
    <p class="market-note">USD checkout · Fast supplier verified · Tracked delivery</p>
    <h1>{{ product.title }}</h1>
    <div class="price-row">
      <strong>{{ current_variant.price | money }}</strong>
      {% if current_variant.compare_at_price > current_variant.price %}
        <span>{{ current_variant.compare_at_price | money }}</span>
      {% endif %}
    </div>

    <div class="product-copy">
      {{ product.description }}
    </div>

    {% render 'trust-badges', delivery_text: section.settings.delivery_text, guarantee_text: section.settings.guarantee_text %}

    {% form 'product', product, class: 'product-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <button class="primary-cta" type="submit" {% unless current_variant.available %}disabled{% endunless %}>
        {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
      </button>
    {% endform %}

    <details class="faq" open>
      <summary>Shipping and returns</summary>
      <p>{{ section.settings.delivery_text }}</p>
      <p>{{ section.settings.guarantee_text }}</p>
    </details>

    {% if product.metafields.custom.faq_json != blank %}
      <div class="faq-list">
        {% assign faqs = product.metafields.custom.faq_json.value %}
        {% for faq in faqs %}
          <details class="faq">
            <summary>{{ faq.question }}</summary>
            <p>{{ faq.answer }}</p>
          </details>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% if section.settings.show_sticky_cta %}
  <div class="sticky-cta" data-sticky-cta>
    <span>{{ product.title }}</span>
    <button type="button" data-add-current> Add to cart </button>
  </div>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": [{% for image in product.images %}{{ image | image_url: width: 1000 | prepend: "https:" | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "sku": {{ current_variant.sku | default: current_variant.id | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": "USD",
    "price": "{{ current_variant.price | divided_by: 100.0 }}",
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}"
  }
}
</script>

{% schema %}
{
  "name": "Dropship product page",
  "settings": [
    { "type": "checkbox", "id": "show_sticky_cta", "label": "Show sticky add to cart", "default": true },
    { "type": "checkbox", "id": "show_ugc_video", "label": "Show UGC video metafield", "default": true },
    { "type": "text", "id": "delivery_text", "label": "Delivery message", "default": "Tracked delivery target: 4-10 business days in supported markets." },
    { "type": "text", "id": "guarantee_text", "label": "Support message", "default": "30-day support window for eligible product issues." }
  ],
  "presets": [{ "name": "Dropship product page" }]
}
{% endschema %}
