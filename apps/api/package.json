{
  "name": "@dropship-os/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@dropship-os/core": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^6.2.1",
    "@sentry/node": "^8.50.0",
    "bullmq": "^5.34.2",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.2",
    "nanoid": "^5.0.9",
    "openai": "^4.79.1",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
